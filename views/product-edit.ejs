<!DOCTYPE html>
<html lang="es">
<!-- Include Head -->

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link width="" rel="shortcut icon" href="./images/logoSolo.png" />

	<title> Mercado Libros Argentina</title>
	<!-- Font Awesome Stylesheet -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.11.2/css/all.min.css">
	<!-- Bootstrap Grid Stylesheet -->
	<link rel="stylesheet" href="/stylesheets/style.css">
	<!-- Own Stylesheet -->
	<link rel="stylesheet" href="/stylesheets/bootstrap-grid.min.css">
</head>

<body>
	<!-- Header -->
	<%- include('./partials/header') %>
	<!-- /Header -->

	<!-- Novedades -->
	<div class="container products-wrapper">
		<div class="row">
			<div class="col-12">
				<h2 class="products-title">Editar datos del producto</h2>
			</div>

			<form action ="/users/profile" method="GET" class="productForm">
					<input type="text" name="nombre" placeholder="Nombre del producto" value="<%= product.nombre %>">
					<input type="text" name="descripcion" placeholder="Descripción del producto" value="<%= product.descripcion %>">
					<input type="text" name="imagen" placeholder="URL de la imagen del producto" value="<%= product.imagen %>">
					<button type="submit">Modificar producto</button>
				</form>

	<!-- Footer -->
	<%- include('./partials/footer') %>
	<!-- /Footer -->
</body>

</html>
