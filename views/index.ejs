<!DOCTYPE html>
<html lang="es">
<!-- Include Head -->

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link width="" rel="shortcut icon" href="./images/logoSolo.png" />

	<title> Mercado Libros Argentina</title>
	<!-- Font Awesome Stylesheet -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.11.2/css/all.min.css">
	<!-- Bootstrap Grid Stylesheet -->
	<link rel="stylesheet" href="/stylesheets/style.css">
	<!-- Own Stylesheet -->
	<link rel="stylesheet" href="/stylesheets/bootstrap-grid.min.css">
</head>

<body>
	<!-- Header -->
	<%- include('./partials/header') %>
		<!-- /Header -->

		<!-- Banner -->
		<div class="banner">
			<img src="images/img-home-banner.jpg" alt="Banner de ofertas">
		</div>
		<!-- /Banner -->

		<!-- Novedades -->
		<div class="container products-wrapper">
			<div class="row product-list">
				<div class="col-12">
					<h2 class="products-title">Productos</h2>
				</div>

				<!-- Show the "ultimos" products -->
				<% for( let i=0; i < productos.length; i++ ) { %>
					<div class="col-12 col-sm-6 col-md-4 col-lg-3 product-column">
						<section class="product-box">
							<a href="/product/detail/<%= productos[i].id %>">
								<figure class="product-box_image">
									<img src="<%= productos[i].imagen %>" alt="<%= productos[i].nombre %>">
								</figure>

								<article class="product-box_data">
									<h2>
										<%= productos[i].nombre %>
									</h2>
									<p class="product-description">
										<%= productos[i].descripcion %>
									</p>
									<p class="product-comments">
										Comentarios: <%= productos[i].cantidadComentarios %>
									</p>
								</article>
							</a>
						</section>
					</div>
				<% } %>
			</div>
		</div>


		<!-- Footer -->
		<%- include('./partials/footer') %>
		<!-- /Footer -->
</body>

</html>