<!DOCTYPE html>
<html lang="es">
<!-- Include Head -->

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link width="" rel="shortcut icon" href="./images/logo-mercado-liebre.jpg" />

	<title> Mercado Liebre Argentina</title>
	<!-- Font Awesome Stylesheet -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.11.2/css/all.min.css">
	<!-- Bootstrap Grid Stylesheet -->
	<link rel="stylesheet" href="/stylesheets/style.css">
	<!-- Own Stylesheet -->
	<link rel="stylesheet" href="/stylesheets/bootstrap-grid.min.css">
</head>

<body>
	<!-- Header -->
	<%- include('./partials/header') %>
	<!-- /Header -->

	<!-- Novedades -->
	<div class="container products-wrapper">
		<div class="row">
			<div class="col-12">
				<h2 class="products-title"><%= title %></h2>
			</div>
			<!-- Show the "ultimos" products -->
      <% for( let i = 0; i < results.length; i++ ) { %>
        <h2 class="col-12">
          <a href="/product/<%= results[i].id %>"><%= results[i].nombre %></a>
        </h2>
      <% } %>
	<!-- Footer -->
	<%- include('./partials/footer') %>
	<!-- /Footer -->
</body>

</html>
